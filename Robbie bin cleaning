<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Halton Bin Cleaning – Georgetown, Ontario</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
 
    :root {
      --navy:   #0b1e35;
      --blue:   #1565c0;
      --sky:    #4fc3f7;
      --white:  #f5f9ff;
      --yellow: #ffe047;
      --grey:   #c9d8e8;
    }
 
    html { scroll-behavior: smooth; }
 
    body {
      background: var(--navy);
      color: var(--white);
      font-family: 'DM Sans', sans-serif;
      overflow-x: hidden;
    }
 
    /* ── HERO ─────────────────────────────────── */
    .hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 2rem 1.5rem 4rem;
      position: relative;
      overflow: hidden;
    }
 
    /* animated water-drop blob background */
    .hero::before {
      content: '';
      position: absolute;
      width: 700px; height: 700px;
      background: radial-gradient(circle at 40% 40%, #1565c055 0%, transparent 65%),
                  radial-gradient(circle at 70% 70%, #4fc3f733 0%, transparent 60%);
      top: -150px; left: 50%;
      transform: translateX(-50%);
      border-radius: 60% 40% 55% 45% / 50% 60% 40% 50%;
      animation: blobPulse 8s ease-in-out infinite alternate;
      pointer-events: none;
    }
 
    @keyframes blobPulse {
      from { border-radius: 60% 40% 55% 45% / 50% 60% 40% 50%; transform: translateX(-50%) scale(1); }
      to   { border-radius: 40% 60% 45% 55% / 60% 40% 60% 40%; transform: translateX(-50%) scale(1.12); }
    }
 
    .badge {
      display: inline-block;
      background: var(--yellow);
      color: var(--navy);
      font-family: 'DM Sans', sans-serif;
      font-weight: 700;
      font-size: .8rem;
      letter-spacing: .12em;
      text-transform: uppercase;
      padding: .35rem 1rem;
      border-radius: 999px;
      margin-bottom: 1.4rem;
      opacity: 0;
      animation: fadeUp .6s .2s forwards;
    }
 
    h1 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(3.5rem, 12vw, 8rem);
      line-height: .95;
      letter-spacing: .02em;
      color: var(--white);
      opacity: 0;
      animation: fadeUp .7s .35s forwards;
    }
    h1 span { color: var(--sky); }
 
    .tagline {
      margin-top: 1.2rem;
      font-size: clamp(1rem, 2.5vw, 1.25rem);
      color: var(--grey);
      max-width: 480px;
      opacity: 0;
      animation: fadeUp .7s .5s forwards;
    }
 
    .price-pill {
      margin-top: 2rem;
      background: var(--yellow);
      color: var(--navy);
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2.2rem;
      letter-spacing: .04em;
      padding: .5rem 2.2rem;
      border-radius: 999px;
      display: inline-block;
      opacity: 0;
      animation: fadeUp .7s .65s forwards;
    }
 
    .cta-group {
      margin-top: 2.2rem;
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      justify-content: center;
      opacity: 0;
      animation: fadeUp .7s .8s forwards;
    }
 
    .btn {
      display: inline-block;
      padding: .85rem 2.2rem;
      border-radius: 6px;
      font-size: 1rem;
      font-weight: 700;
      text-decoration: none;
      transition: transform .15s, box-shadow .15s;
      cursor: pointer;
    }
    .btn:hover { transform: translateY(-3px); box-shadow: 0 8px 24px #0006; }
 
    .btn-primary { background: var(--sky); color: var(--navy); }
    .btn-outline  { background: transparent; color: var(--white); border: 2px solid #ffffff55; }
    .btn-outline:hover { border-color: var(--sky); color: var(--sky); }
 
    .scroll-hint {
      position: absolute;
      bottom: 2rem;
      left: 50%;
      transform: translateX(-50%);
      color: var(--grey);
      font-size: .78rem;
      letter-spacing: .12em;
      text-transform: uppercase;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: .4rem;
      opacity: .6;
      animation: bounce 2s infinite;
    }
    .scroll-hint svg { width: 20px; }
 
    @keyframes bounce {
      0%,100% { transform: translateX(-50%) translateY(0); }
      50%      { transform: translateX(-50%) translateY(6px); }
    }
 
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(22px); }
      to   { opacity: 1; transform: translateY(0); }
    }
 
    /* ── DIVIDER ────────────────────────────── */
    .wave-divider { display: block; width: 100%; line-height: 0; }
 
    /* ── HOW IT WORKS ─────────────────────── */
    .section { padding: 5rem 1.5rem; }
    .section-inner { max-width: 1000px; margin: 0 auto; }
 
    .section-label {
      font-family: 'DM Sans', sans-serif;
      font-weight: 700;
      font-size: .75rem;
      letter-spacing: .15em;
      text-transform: uppercase;
      color: var(--sky);
      margin-bottom: .7rem;
    }
 
    h2 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2.4rem, 6vw, 4rem);
      line-height: 1;
      color: var(--white);
      margin-bottom: 3rem;
    }
 
    .steps {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1.5rem;
    }
 
    .step-card {
      background: #ffffff08;
      border: 1px solid #ffffff14;
      border-radius: 12px;
      padding: 2rem 1.6rem;
      transition: transform .2s, border-color .2s;
    }
    .step-card:hover { transform: translateY(-4px); border-color: var(--sky); }
 
    .step-number {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 3.5rem;
      color: var(--sky);
      line-height: 1;
      margin-bottom: .5rem;
    }
 
    .step-card h3 { font-size: 1.15rem; font-weight: 700; margin-bottom: .5rem; }
    .step-card p  { font-size: .93rem; color: var(--grey); line-height: 1.6; }
 
    /* ── WHY SECTION ─────────────────────── */
    .why-bg {
      background: #0d2340;
    }
 
    .why-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1.2rem;
      margin-top: 3rem;
    }
 
    .why-card {
      background: #ffffff08;
      border-radius: 10px;
      padding: 1.5rem;
      border-left: 3px solid var(--sky);
    }
    .why-card .icon { font-size: 1.8rem; margin-bottom: .6rem; }
    .why-card h4 { font-weight: 700; margin-bottom: .3rem; font-size: 1rem; }
    .why-card p  { font-size: .88rem; color: var(--grey); line-height: 1.55; }
 
    /* ── PRICING ──────────────────────────── */
    .pricing-box {
      max-width: 460px;
      margin: 2.5rem auto 0;
      background: var(--yellow);
      color: var(--navy);
      border-radius: 16px;
      padding: 2.5rem 2rem;
      text-align: center;
    }
    .pricing-box .big { font-family: 'Bebas Neue', sans-serif; font-size: 5rem; line-height: 1; }
    .pricing-box .sub { font-size: 1rem; font-weight: 500; margin-top: .4rem; color: #0b3060; }
    .pricing-box .note { margin-top: 1.2rem; font-size: .85rem; color: #0b3060; }
 
    /* ── CONTACT ─────────────────────────── */
    .contact-section { background: #071527; }
 
    .contact-card {
      max-width: 560px;
      margin: 0 auto;
      background: #ffffff08;
      border: 1px solid #ffffff16;
      border-radius: 14px;
      padding: 2.5rem 2rem;
      text-align: center;
    }
    .contact-card p { color: var(--grey); margin-bottom: 1.5rem; font-size: 1rem; }
 
    .phone-link {
      display: inline-block;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 3rem;
      color: var(--sky);
      text-decoration: none;
      letter-spacing: .05em;
      transition: color .15s;
    }
    .phone-link:hover { color: var(--yellow); }
 
    .location-tag {
      margin-top: 1.2rem;
      display: inline-flex;
      align-items: center;
      gap: .4rem;
      font-size: .88rem;
      color: var(--grey);
    }
    .location-tag svg { width: 14px; flex-shrink: 0; }
 
    /* ── FOOTER ──────────────────────────── */
    footer {
      text-align: center;
      padding: 2rem 1.5rem;
      font-size: .8rem;
      color: #4a6580;
      border-top: 1px solid #ffffff0d;
    }
 
    /* ── MOBILE ──────────────────────────── */
    @media (max-width: 520px) {
      .btn { padding: .75rem 1.6rem; font-size: .95rem; }
    }
  </style>
</head>
